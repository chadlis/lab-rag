{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Search: query movies",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/cli/keyword_search_cli.py",
            "args": ["search", "action", "--limit", "5", "--verbose"],
            "cwd": "${workspaceFolder}/cli",
            "env": {
                "DATA_DIR": "${workspaceFolder}/data",
                "CACHE_DIR": "${workspaceFolder}/cache",
                "ASSETS_DIR": "${workspaceFolder}/assets"
            }
        },
        {
            "name": "Build: inverted index",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/cli/keyword_search_cli.py",
            "args": ["build", "--verbose"],
            "cwd": "${workspaceFolder}/cli",
            "env": {
                "DATA_DIR": "${workspaceFolder}/data",
                "CACHE_DIR": "${workspaceFolder}/cache",
                "ASSETS_DIR": "${workspaceFolder}/assets"
            }
        },
        {
            "name": "TFIDF: doc 424, term 'trapper'",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/cli/keyword_search_cli.py",
            "args": ["tfidf", "424", "trapper"],
            "cwd": "${workspaceFolder}/cli",
            "env": {
                "DATA_DIR": "${workspaceFolder}/data",
                "CACHE_DIR": "${workspaceFolder}/cache",
                "ASSETS_DIR": "${workspaceFolder}/assets"
            }
        },
        {
            "name": "BM25 Search: love story",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/cli/keyword_search_cli.py",
            "args": ["bm25search", "love story"],
            "cwd": "${workspaceFolder}/cli",
            "env": {
                "DATA_DIR": "${workspaceFolder}/data",
                "CACHE_DIR": "${workspaceFolder}/cache",
                "ASSETS_DIR": "${workspaceFolder}/assets"
            }
        }
    ]
}
